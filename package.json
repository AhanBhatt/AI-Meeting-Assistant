{
  "name": "zoom-copilot",
  "private": true,
  "version": "0.1.0",
  "description": "AI Meeting Assistance desktop copilot for interview and meeting support.",
  "author": "Ahan Bhatt <bhattahan@gmail.com>",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "node scripts/clean-dev-ports.cjs",
    "dev": "concurrently -k \"vite\" \"cross-env NODE_ENV=development tsx watch server/standalone.ts\" \"npm run electron\"",
    "electron": "wait-on tcp:5173 && cmd /d /s /c \"set ELECTRON_RUN_AS_NODE=&& electron electron/dev-runner.cjs\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:server": "tsc -p server/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron && npm run build:server && node scripts/write-runtime-package-json.cjs",
    "start": "node dist-server/standalone.js",
    "start:prod": "cmd /d /s /c \"set ELECTRON_RUN_AS_NODE=&& set NODE_ENV=production&& electron .\"",
    "pack:win": "npm run build && electron-builder --win nsis --dir",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "concurrently": "^9.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wait-on": "^7.2.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.ahanbhatt.aimeetingassistance",
    "productName": "AI Meeting Assistance",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "dist-server/**",
      "electron/preload.js",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Meeting Assistance",
      "artifactName": "AI-Meeting-Assistance-Setup-${version}.${ext}"
    }
  }
}
